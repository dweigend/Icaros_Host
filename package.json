{
	"name": "icaros-host",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:lan": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "vite preview",
		"serve": "bun server/index.ts",
		"serve:lan": "PORT=5183 HOST=0.0.0.0 bun server/index.ts",
		"start:clean": "scripts/start-host-clean.sh",
		"hardware:host": "bun run build && bun run serve:lan",
		"serve:e2e": "PORT=5183 HOST=0.0.0.0 bun server/index.ts",
		"firmware:m5:build": "uvx --from platformio platformio run -d firmware/m5-controller",
		"m5:pairing": "bun scripts/m5-pairing-cli.ts",
		"smoke:runtime": "bun scripts/smoke-runtime.ts",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/three": "^0.184.1",
		"@types/ws": "^8.18.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"three": "^0.184.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@lucide/svelte": "^1.17.0",
		"bits-ui": "^2.18.1",
		"ws": "^8.21.0"
	}
}
